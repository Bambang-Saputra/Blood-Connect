// =====================================================================
// BLOOD CONNECT - Database Schema (v3 - PMI Restructure)
// =====================================================================
// Major changes from v2:
//   - Role RUMAH_SAKIT -> PMI (Palang Merah Indonesia / UTD)
//   - Model RumahSakit -> PMI (keeps DB table for compat via @@map)
//   - RequestStatus simplified: PENDING -> ACC -> SHIPPED -> DELIVERED -> FULFILLED
//   - PermintaanDonor: targetHospital fields, no more urgency
//   - Pendonor: preferredPmiId (PMI yang dipilih untuk donor)
//   - JadwalDonor: pmiId (lokasi donor)
//   - StokDarah: status default AVAILABLE (no more QUARANTINE)
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------

enum Role {
  PENDONOR
  PASIEN
  PMI           // dulu RUMAH_SAKIT — sekarang Palang Merah Indonesia / UTD
  ADMIN
}

enum BloodType {
  A
  B
  AB
  O
}

enum RhesusType {
  POSITIVE
  NEGATIVE
}

enum BloodComponent {
  WHOLE_BLOOD
  PRC
  FFP
  TC
  CRYO
}

// Workflow request darah dari pasien:
//   PENDING   = baru dibuat, menunggu PMI proses
//   ACC       = PMI sudah konfirmasi, stok dialokasikan
//   SHIPPED   = PMI sedang kirim ke RS pasien
//   DELIVERED = sudah sampai di RS pasien
//   FULFILLED = transaksi selesai (darah diterima pasien)
//   REJECTED  = ditolak PMI / tidak bisa dipenuhi
//   CANCELLED = dibatalkan pasien
//   SEARCHING = broadcast ke donor karena stok kurang
enum RequestStatus {
  PENDING
  ACC
  SHIPPED
  DELIVERED
  FULFILLED
  SEARCHING
  REJECTED
  CANCELLED
}

enum StockStatus {
  AVAILABLE
  RESERVED       // dialokasikan untuk request tertentu
  EXPIRED
  USED
}

enum ScheduleStatus {
  PENDING
  CONFIRMED
  REJECTED
  RESCHEDULED
  COMPLETED
  CANCELLED
}

enum PmiStatus {
  UNVERIFIED
  VERIFIED
  SUSPENDED
}

enum NotificationType {
  ELIGIBLE_DONOR_REQUEST
  REQUEST_STATUS_UPDATE
  SCHEDULE_UPDATE
  STOCK_ALERT
  ACCOUNT_VERIFICATION
  GENERIC
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  STOCK_ALLOCATE
}

// ---------------------------------------------------------------------
// USER (base)
// ---------------------------------------------------------------------
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  phoneNum    String
  address     String?
  city        String
  province    String?
  zone        String?
  birthDate   DateTime?
  role        Role
  isBlocked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pendonor      Pendonor?
  pasien        Pasien?
  pmi           PMI?
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([city])
  @@index([province])
  @@index([zone])
  @@index([role])
}

// ---------------------------------------------------------------------
// PENDONOR
// ---------------------------------------------------------------------
model Pendonor {
  id                String      @id @default(cuid())
  userId            String      @unique
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  bloodType         BloodType
  rhesusType        RhesusType
  weight            Float?
  lastDonationDate  DateTime?
  isActive          Boolean     @default(true)
  isEligible        Boolean     @default(false)
  eligibilityReason String?
  totalDonations    Int         @default(0)

  // PMI tempat donor terdaftar (untuk routing donor)
  preferredPmiId    String?
  preferredPmi      PMI?        @relation(fields: [preferredPmiId], references: [id])

  schedules         JadwalDonor[]
  history           DonorHistory[]
  notifResponses    DonorNotification[]
  checkups          PemeriksaanDonor[]
  screenings        ScreeningAnswer[]

  @@index([bloodType, rhesusType, isEligible])
  @@index([preferredPmiId])
}

// ---------------------------------------------------------------------
// PEMERIKSAAN DONOR (oleh PMI)
// ---------------------------------------------------------------------
model PemeriksaanDonor {
  id                  String   @id @default(cuid())
  donorId             String
  donor               Pendonor @relation(fields: [donorId], references: [id], onDelete: Cascade)
  examinedAt          DateTime @default(now())
  examinedBy          String?
  hemoglobinLevel     Float
  systolicBP          Int
  diastolicBP         Int
  bodyTempC           Float
  pulseRate           Int
  weight              Float
  notes               String?
  passed              Boolean

  @@index([donorId, examinedAt])
}

// ---------------------------------------------------------------------
// SCREENING ANSWER (diisi donor sendiri)
// ---------------------------------------------------------------------
model ScreeningAnswer {
  id            String   @id @default(cuid())
  donorId       String
  donor         Pendonor @relation(fields: [donorId], references: [id], onDelete: Cascade)
  answeredAt    DateTime @default(now())

  hasFever              Boolean @default(false)
  recentSurgery         Boolean @default(false)
  recentTattoo          Boolean @default(false)
  isPregnantOrLactating Boolean @default(false)
  onMedication          Boolean @default(false)
  hasHIVOrHepatitis     Boolean @default(false)
  riskySexualBehavior   Boolean @default(false)
  recentVaccination     Boolean @default(false)
  details               String?

  passed        Boolean
}

// ---------------------------------------------------------------------
// PASIEN
// ---------------------------------------------------------------------
model Pasien {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nik         String?  @unique

  requests    PermintaanDonor[]
}

// ---------------------------------------------------------------------
// PMI (Palang Merah Indonesia / Unit Transfusi Darah)
// Dulu disebut RumahSakit di v2 — sekarang semantically PMI.
// Tabel underlying tetap "RumahSakit" via @@map untuk kompat data lama.
// ---------------------------------------------------------------------
model PMI {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pmiName       String     @map("hospitalName")
  pmiCode       String     @unique @map("hospitalCode")
  pmiLoc        String     @map("hospitalLoc")
  status        PmiStatus  @default(UNVERIFIED)
  verifiedAt    DateTime?
  verifiedById  String?
  licenseDoc    String?

  stocks        StokDarah[]
  requests      PermintaanDonor[]
  registeredDonors Pendonor[]
  schedules     JadwalDonor[]

  @@map("RumahSakit")
}

// ---------------------------------------------------------------------
// STOK DARAH (di PMI)
// ---------------------------------------------------------------------
model StokDarah {
  id            String         @id @default(cuid())
  pmiId         String         @map("hospitalId")
  pmi           PMI            @relation(fields: [pmiId], references: [id])

  bloodType     BloodType
  rhesusType    RhesusType
  component     BloodComponent @default(WHOLE_BLOOD)
  quantity      Int
  expiryDate    DateTime
  location      String
  status        StockStatus    @default(AVAILABLE)   // langsung AVAILABLE, no quarantine
  source        String?
  donorId       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  allocations   StockAllocation[]

  @@index([bloodType, rhesusType, component, status, expiryDate])
  @@index([location])
}

// ---------------------------------------------------------------------
// PERMINTAAN DONOR (dari Pasien ke PMI, lalu ke RS Pasien)
// ---------------------------------------------------------------------
model PermintaanDonor {
  id            String         @id @default(cuid())
  patientId     String?
  patient       Pasien?        @relation(fields: [patientId], references: [id])

  // PMI yang handle request ini (auto-assigned berdasarkan city)
  pmiId         String?        @map("hospitalId")
  pmi           PMI?           @relation(fields: [pmiId], references: [id])

  bloodType     BloodType
  rhesusType    RhesusType
  component     BloodComponent @default(WHOLE_BLOOD)
  quantity      Int

  // Info RS tujuan kirim darah
  targetHospitalName     String?
  targetHospitalAddress  String?
  doctorName             String?
  familyContact          String?

  reason        String?
  reqStatus     RequestStatus  @default(PENDING)
  shippedAt     DateTime?
  deliveredAt   DateTime?
  fulfilledAt   DateTime?
  rejectedReason String?
  createdAt     DateTime       @default(now())

  allocations   StockAllocation[]
  donorNotifs   DonorNotification[]

  @@index([reqStatus, createdAt])
  @@index([bloodType, rhesusType, component])
  @@index([pmiId])
}

// ---------------------------------------------------------------------
// STOCK ALLOCATION
// ---------------------------------------------------------------------
model StockAllocation {
  id          String           @id @default(cuid())
  requestId   String
  request     PermintaanDonor  @relation(fields: [requestId], references: [id])
  stockId     String
  stock       StokDarah        @relation(fields: [stockId], references: [id])
  quantity    Int
  createdAt   DateTime         @default(now())

  @@unique([requestId, stockId])
}

// ---------------------------------------------------------------------
// JADWAL DONOR (donor pilih tanggal + jam + PMI lokasi)
// ---------------------------------------------------------------------
model JadwalDonor {
  id          String         @id @default(cuid())
  donorId     String
  donor       Pendonor       @relation(fields: [donorId], references: [id])
  pmiId       String?
  pmi         PMI?           @relation(fields: [pmiId], references: [id])

  jadwal      DateTime
  sesi        String         // PAGI / SIANG / SORE
  status      ScheduleStatus @default(PENDING)
  newDate     DateTime?
  note        String?

  // Optional link ke request yang di-volunteer (kalau donor accept broadcast)
  linkedRequestId String?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([jadwal, status])
  @@index([pmiId])
}

// ---------------------------------------------------------------------
// DONOR HISTORY
// ---------------------------------------------------------------------
model DonorHistory {
  id          String         @id @default(cuid())
  donorId     String
  donor       Pendonor       @relation(fields: [donorId], references: [id])
  donationDate DateTime      @default(now())
  location    String
  volumeMl    Int            @default(450)
  component   BloodComponent @default(WHOLE_BLOOD)
  note        String?

  @@index([donorId, donationDate])
}

// ---------------------------------------------------------------------
// DONOR NOTIFICATION (PMI broadcast ke donor compatible)
// ---------------------------------------------------------------------
model DonorNotification {
  id          String          @id @default(cuid())
  donorId     String
  donor       Pendonor        @relation(fields: [donorId], references: [id])
  requestId   String
  request     PermintaanDonor @relation(fields: [requestId], references: [id])
  notifiedAt  DateTime        @default(now())
  responded   Boolean         @default(false)
  accepted    Boolean?
  respondedAt DateTime?

  @@unique([donorId, requestId])
  @@index([requestId, responded])
}

// ---------------------------------------------------------------------
// NOTIFICATION (in-app inbox)
// ---------------------------------------------------------------------
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  meta      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}

// ---------------------------------------------------------------------
// AUDIT LOG
// ---------------------------------------------------------------------
model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  action      AuditAction
  entity      String
  entityId    String
  before      Json?
  after       Json?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
}
