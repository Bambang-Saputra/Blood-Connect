// =====================================================================
// BLOOD CONNECT - Database Schema (v3 - PMI as central blood bank)
// =====================================================================
// Perubahan vs v2:
//   - Rebrand RumahSakit → PMI (Palang Merah Indonesia / UTD)
//   - JadwalDonor scoped per PMI (donor pilih PMI saat schedule)
//   - PermintaanDonor: target hospital free-text, broadcast ke semua PMI
//   - PemeriksaanDonor: scoped per PMI (cek fisik dilakukan di PMI)
//   - Eligibility: dihitung saat PMI selesai input checkup
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------

enum Role {
  PENDONOR
  PASIEN
  PMI
  ADMIN
}

enum BloodType {
  A
  B
  AB
  O
}

enum RhesusType {
  POSITIVE
  NEGATIVE
}

enum BloodComponent {
  WHOLE_BLOOD
  PRC
  FFP
  TC
  CRYO
}

enum RequestStatus {
  PENDING
  PROCESSING
  MATCHED_STOCK
  MATCHED_DONOR
  IN_TRANSIT
  FULFILLED
  REJECTED
  CANCELLED
}

enum StockStatus {
  AVAILABLE
  RESERVED
  EXPIRED
  USED
  QUARANTINE
}

enum ScheduleStatus {
  PENDING
  CONFIRMED
  REJECTED
  RESCHEDULED
  COMPLETED
  CANCELLED
}

enum PmiStatus {
  UNVERIFIED
  VERIFIED
  SUSPENDED
}

enum NotificationType {
  ELIGIBLE_DONOR_REQUEST
  REQUEST_STATUS_UPDATE
  SCHEDULE_UPDATE
  STOCK_ALERT
  ACCOUNT_VERIFICATION
  PMI_BROADCAST           // PMI minta stok darah ke donor terdekat
  GENERIC
}

enum BroadcastStatus {
  OPEN                    // masih butuh donor
  CLOSED                  // target tercapai atau ditutup manual
  EXPIRED                 // melewati expiresAt
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  STOCK_ALLOCATE
}

// ---------------------------------------------------------------------
// USER (base)
// ---------------------------------------------------------------------
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  phoneNum    String
  address     String?
  city        String
  province    String?
  zone        String?
  birthDate   DateTime?
  role        Role
  isBlocked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pendonor      Pendonor?
  pasien        Pasien?
  pmi           PMI?
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([city])
  @@index([province])
  @@index([zone])
  @@index([role])
}

// ---------------------------------------------------------------------
// PENDONOR
// ---------------------------------------------------------------------
model Pendonor {
  id                String      @id @default(cuid())
  userId            String      @unique
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  bloodType         BloodType
  rhesusType        RhesusType
  weight            Float?
  lastDonationDate  DateTime?
  isActive          Boolean     @default(true)
  isEligible        Boolean     @default(false)
  eligibilityReason String?
  totalDonations    Int         @default(0)

  // Optional: PMI default pilihan donor (untuk future broadcast PMI→donor)
  preferredPmiId    String?
  preferredPmi      PMI?        @relation("DonorPreferredPMI", fields: [preferredPmiId], references: [id])

  schedules         JadwalDonor[]
  history           DonorHistory[]
  notifResponses    DonorNotification[]
  checkups          PemeriksaanDonor[]
  screenings        ScreeningAnswer[]

  @@index([bloodType, rhesusType, isEligible])
  @@index([preferredPmiId])
}

// ---------------------------------------------------------------------
// PEMERIKSAAN DONOR — cek fisik dilakukan di PMI
// ---------------------------------------------------------------------
model PemeriksaanDonor {
  id                  String   @id @default(cuid())
  donorId             String
  donor               Pendonor @relation(fields: [donorId], references: [id], onDelete: Cascade)
  pmiId               String?
  pmi                 PMI?     @relation(fields: [pmiId], references: [id])
  examinedAt          DateTime @default(now())
  examinedBy          String?
  hemoglobinLevel     Float
  systolicBP          Int
  diastolicBP         Int
  bodyTempC           Float
  pulseRate           Int
  weight              Float
  notes               String?
  passed              Boolean

  // Reverse relation: 1 checkup mungkin terkait dengan 1 jadwal donor
  jadwal              JadwalDonor?

  @@index([donorId, examinedAt])
  @@index([pmiId, examinedAt])
}

// ---------------------------------------------------------------------
// SCREENING ANSWER — kuesioner pre-donor (diisi donor sendiri)
// ---------------------------------------------------------------------
model ScreeningAnswer {
  id            String   @id @default(cuid())
  donorId       String
  donor         Pendonor @relation(fields: [donorId], references: [id], onDelete: Cascade)
  answeredAt    DateTime @default(now())

  hasFever              Boolean @default(false)
  recentSurgery         Boolean @default(false)
  recentTattoo          Boolean @default(false)
  isPregnantOrLactating Boolean @default(false)
  onMedication          Boolean @default(false)
  hasHIVOrHepatitis     Boolean @default(false)
  riskySexualBehavior   Boolean @default(false)
  recentVaccination     Boolean @default(false)
  details               String?

  passed        Boolean

  // Reverse relation: 1 screening bisa dipakai 1 jadwal
  jadwal        JadwalDonor?
}

// ---------------------------------------------------------------------
// PASIEN
// ---------------------------------------------------------------------
model Pasien {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nik         String?  @unique

  requests    PermintaanDonor[]
}

// ---------------------------------------------------------------------
// PMI — pusat blood bank (was RumahSakit)
// ---------------------------------------------------------------------
model PMI {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pmiName       String
  pmiCode       String         @unique
  pmiLoc        String
  status        PmiStatus      @default(UNVERIFIED)
  verifiedAt    DateTime?
  verifiedById  String?
  licenseDoc    String?

  stocks            StokDarah[]
  acceptedRequests  PermintaanDonor[]   @relation("RequestAcceptedByPMI")
  schedules         JadwalDonor[]
  examinations      PemeriksaanDonor[]
  donorPreferences  Pendonor[]          @relation("DonorPreferredPMI")
  broadcasts        PmiBroadcast[]
}

// ---------------------------------------------------------------------
// STOK DARAH — per-batch, dimiliki PMI
// ---------------------------------------------------------------------
model StokDarah {
  id            String         @id @default(cuid())
  pmiId         String
  pmi           PMI            @relation(fields: [pmiId], references: [id])

  bloodType     BloodType
  rhesusType    RhesusType
  component     BloodComponent @default(WHOLE_BLOOD)
  quantity      Int
  expiryDate    DateTime
  location      String
  // Default AVAILABLE — admin tidak lagi terlibat verifikasi quarantine.
  // PMI bertanggung jawab penuh atas validasi internal sebelum input ke sistem.
  status        StockStatus    @default(AVAILABLE)
  source        String?
  donorId       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  allocations   StockAllocation[]

  @@index([bloodType, rhesusType, component, status, expiryDate])
  @@index([location])
  @@index([pmiId])
}

// ---------------------------------------------------------------------
// PMI BROADCAST — PMI minta stok darah ke donor terdekat (kota sama)
// ---------------------------------------------------------------------
model PmiBroadcast {
  id              String          @id @default(cuid())
  pmiId           String
  pmi             PMI             @relation(fields: [pmiId], references: [id])
  bloodType       BloodType
  rhesusType      RhesusType
  targetQuantity  Int
  filledQuantity  Int             @default(0)   // qty yang sudah didapat dari donor (manual track)
  message         String?
  status          BroadcastStatus @default(OPEN)
  expiresAt       DateTime?                      // null = tidak ada deadline
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([pmiId, status, createdAt])
  @@index([bloodType, rhesusType, status])
}

// ---------------------------------------------------------------------
// PERMINTAAN DONOR — broadcast ke SEMUA PMI
// ---------------------------------------------------------------------
model PermintaanDonor {
  id                    String         @id @default(cuid())
  patientId             String?
  patient               Pasien?        @relation(fields: [patientId], references: [id])

  // Target RS tempat pasien dirawat (free-text — bukan relation ke PMI)
  targetHospitalName    String
  targetHospitalAddress String?

  // PMI yang accept request (null kalau masih PENDING / broadcast)
  acceptedByPmiId       String?
  acceptedByPmi         PMI?           @relation("RequestAcceptedByPMI", fields: [acceptedByPmiId], references: [id])

  bloodType     BloodType
  rhesusType    RhesusType
  component     BloodComponent @default(WHOLE_BLOOD)
  quantity      Int
  // urgency: KEEP di DB tapi NOT input dari pasien.
  // Server compute saat read berdasarkan total stok PMI untuk golongan ini.
  urgency       String         @default("NORMAL")
  reason        String?
  doctorName    String?
  reqStatus     RequestStatus  @default(PENDING)
  createdAt     DateTime       @default(now())
  fulfilledAt   DateTime?

  allocations   StockAllocation[]
  donorNotifs   DonorNotification[]

  @@index([reqStatus, createdAt])
  @@index([bloodType, rhesusType, component])
  @@index([acceptedByPmiId])
}

// ---------------------------------------------------------------------
// STOCK ALLOCATION
// ---------------------------------------------------------------------
model StockAllocation {
  id          String           @id @default(cuid())
  requestId   String
  request     PermintaanDonor  @relation(fields: [requestId], references: [id])
  stockId     String
  stock       StokDarah        @relation(fields: [stockId], references: [id])
  quantity    Int
  createdAt   DateTime         @default(now())

  @@unique([requestId, stockId])
}

// ---------------------------------------------------------------------
// JADWAL DONOR — scoped per PMI
// ---------------------------------------------------------------------
model JadwalDonor {
  id          String         @id @default(cuid())
  donorId     String
  donor       Pendonor       @relation(fields: [donorId], references: [id])
  pmiId       String
  pmi         PMI            @relation(fields: [pmiId], references: [id])
  jadwal      DateTime
  sesi        String
  status      ScheduleStatus @default(PENDING)
  newDate     DateTime?
  note        String?

  // Resume skrining donor yang dipakai untuk jadwal ini
  screeningId String?        @unique
  screening   ScreeningAnswer? @relation(fields: [screeningId], references: [id])

  // Hasil cek fisik PMI untuk jadwal ini
  checkupId   String?        @unique
  checkup     PemeriksaanDonor? @relation(fields: [checkupId], references: [id])

  // Eligibility evaluation: null = belum dicek, true/false setelah PMI input checkup
  isEligible        Boolean?
  eligibilityReason String?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([jadwal, status])
  @@index([pmiId, status])
  @@index([donorId, status])
}

// ---------------------------------------------------------------------
// DONOR HISTORY
// ---------------------------------------------------------------------
model DonorHistory {
  id           String         @id @default(cuid())
  donorId      String
  donor        Pendonor       @relation(fields: [donorId], references: [id])
  donationDate DateTime       @default(now())
  location     String
  volumeMl     Int            @default(450)
  component    BloodComponent @default(WHOLE_BLOOD)
  note         String?

  @@index([donorId, donationDate])
}

// ---------------------------------------------------------------------
// DONOR NOTIFICATION
// ---------------------------------------------------------------------
model DonorNotification {
  id          String          @id @default(cuid())
  donorId     String
  donor       Pendonor        @relation(fields: [donorId], references: [id])
  requestId   String
  request     PermintaanDonor @relation(fields: [requestId], references: [id])
  notifiedAt  DateTime        @default(now())
  responded   Boolean         @default(false)
  accepted    Boolean?
  respondedAt DateTime?

  @@unique([donorId, requestId])
  @@index([requestId, responded])
}

// ---------------------------------------------------------------------
// NOTIFICATION (in-app)
// ---------------------------------------------------------------------
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  meta      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}

// ---------------------------------------------------------------------
// AUDIT LOG
// ---------------------------------------------------------------------
model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  action      AuditAction
  entity      String
  entityId    String
  before      Json?
  after       Json?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
}
