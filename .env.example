# --- Database (Neon.tech recommended) ---
# Daftar gratis di https://neon.tech, copy connection string
DATABASE_URL="postgresql://user:password@ep-xxxxx.neon.tech/neondb?sslmode=require"

# --- Auth ---
JWT_SECRET="ganti-dengan-string-acak-256-bit-untuk-production"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# --- CORS Whitelist ---
# Comma-separated, jangan ada spasi di antara
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# --- Admin Bootstrap (optional, dipakai oleh `npm run admin:create`) ---
ADMIN_EMAIL="admin@bloodconnect.id"
ADMIN_PASSWORD="admin12345"
ADMIN_NAME="Super Admin"

# --- Email Notification (Nodemailer SMTP, optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=app-password
SMTP_FROM="Blood Connect <no-reply@bloodconnect.id>"
